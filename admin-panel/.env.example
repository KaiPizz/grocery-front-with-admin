# Admin API authentication key (required for write operations from storefront)
ADMIN_API_KEY=change-me-to-a-secure-random-string

# Client-side API key (must match ADMIN_API_KEY for the admin UI to call its own API)
NEXT_PUBLIC_ADMIN_API_KEY=change-me-to-a-secure-random-string

# Salon slug (identifies which storefront config to manage)
NEXT_PUBLIC_SALON_SLUG=my-grocery-store

# Allowed CORS origin (storefront URL). Use * for dev, restrict in production.
CORS_ORIGIN=http://localhost:3008

# === Admin Login Credentials ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-secure-password
ADMIN_SESSION_SECRET=change-me-to-a-random-64-char-string-for-cookie-signing

# Optional: Zyra API URL for proxying media uploads
# ZYRA_API_URL=https://zira-ai.com/api/v1
