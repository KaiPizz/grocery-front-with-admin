# === Admin authentication ===
ADMIN_USERNAME=replace-with-a-non-default-username
# Generate this with the repository password-hash helper; never store plaintext here.
ADMIN_PASSWORD_HASH=paste-generated-scrypt-hash
# Generate at least 32 random bytes and keep the value server-side only.
ADMIN_SESSION_SECRET=paste-generated-session-secret

# === Tenant scope ===
# Comma-separated server-side allowlist. Production fails closed when omitted.
ADMIN_ALLOWED_SLUGS=your-store
# Client-side slug used by the editor UI (must be included above).
NEXT_PUBLIC_SALON_SLUG=your-store

# === Persistent storage ===
# Development may use ./data and ./public/uploads. Production requires absolute,
# release-independent shared paths.
ADMIN_DATA_DIR=./data
ADMIN_UPLOAD_DIR=./public/uploads
ADMIN_PUBLIC_ORIGIN=http://localhost:4100

# Origins allowed to read the public published-config GET endpoint.
# Use comma-separated exact origins; wildcard is accepted only outside production.
STOREFRONT_ORIGINS=http://localhost:3008

# Optional: Zyra API URL for future server-side integrations.
# ZYRA_API_URL=https://zira-ai.com/api/v1
