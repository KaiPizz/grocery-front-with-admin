# === Required ===
# Backend API URL (NestJS)
NEXT_PUBLIC_API_URL=https://zira-ai.com/api/v1

# GraphQL Storefront endpoint
NEXT_PUBLIC_GRAPHQL_URL=https://zira-ai.com/graphql/storefront

# Salon slug (identifies which store's data to load)
NEXT_PUBLIC_SALON_SLUG=my-grocery-store

# === Optional ===
# Override GraphQL channel (defaults to salon slug)
# NEXT_PUBLIC_CHANNEL=default

# Store branding
# NEXT_PUBLIC_STORE_NAME=My Grocery Store
# NEXT_PUBLIC_STORE_DESCRIPTION=Fresh groceries delivered to your door

# === Optional Admin Panel Config API ===
# Set only when using admin-panel runtime config. Omit to use built-in fallbacks.
# NEXT_PUBLIC_CONFIG_API_URL=http://localhost:4100

# Admin UI for managing store operations/products
# NEXT_PUBLIC_ADMIN_URL=http://localhost:4100/admin
