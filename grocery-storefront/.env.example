# === Required ===
# Backend API URL (NestJS)
NEXT_PUBLIC_API_URL=https://zira-ai.com/api/v1

# GraphQL Storefront endpoint
NEXT_PUBLIC_GRAPHQL_URL=https://zira-ai.com/graphql/storefront

# Salon slug (identifies which store's data to load)
NEXT_PUBLIC_SALON_SLUG=kenmito

# === Optional ===
# Override GraphQL channel (defaults to salon slug)
NEXT_PUBLIC_CHANNEL=kenmito

# Enable customer Google sign-in. This is a public OAuth client identifier,
# but it stays server-side so the provider can be disabled without rebuilding.
# CUSTOMER_GOOGLE_CLIENT_ID=000000000000-example.apps.googleusercontent.com
# Enable customer Facebook sign-in. Both values are server-only feature gates.
# CUSTOMER_FACEBOOK_APP_ID=000000000000000
# CUSTOMER_FACEBOOK_GRAPH_VERSION=vN.N
# Shared only between this BFF and the backend. Generate an independent,
# high-entropy value in each environment; never expose it as NEXT_PUBLIC_*.
# CUSTOMER_AUTH_BFF_SECRET=
# Dedicated private/loopback backend endpoint used only for customer social auth.
# CUSTOMER_AUTH_GRAPHQL_URL=http://127.0.0.1:3003/graphql/storefront

# Store branding
NEXT_PUBLIC_STORE_NAME=Kenmito
NEXT_PUBLIC_STORE_DESCRIPTION=Asian grocery store

# === Optional Admin Panel Config API ===
# Set only when using admin-panel runtime config. Omit to use built-in fallbacks.
# NEXT_PUBLIC_CONFIG_API_URL=https://kenmito-admin.enail.pro
# Optional comma-separated exact HTTPS hosts for additional trusted image CDNs.
# IMAGE_PROXY_ALLOWED_HOSTS=cdn.example.com,media.example.com

# === Optional Static Storefront Config ===
# Used as an explicit fallback when admin config API is unavailable.
# NEXT_PUBLIC_STATIC_CONFIG_URL=https://kenmito.enail.pro/config/kenmito.json

# Admin UI for managing store operations/products
# NEXT_PUBLIC_ADMIN_URL=https://kenmito-admin.enail.pro/admin
